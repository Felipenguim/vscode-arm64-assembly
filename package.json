{
  "name": "vscode-arm64-assembly",
  "displayName": "ARM64 Assembly (GNU AS)",
  "description": "ARM64/AArch64 GNU Assembler support: syntax highlighting, outline, go-to-definition, and register hover docs for all AArch64 registers",
  "version": "0.1.0",
  "publisher": "arm64asm",
  "license": "MIT",
  "icon": "images/icon.png",
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "arm64",
    "aarch64",
    "assembly",
    "gnu as",
    "gas",
    "asm",
    "bare-metal",
    "syscall"
  ],
  "engines": {
    "vscode": "^1.115.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_GITHUB/vscode-arm64-assembly.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_GITHUB/vscode-arm64-assembly/issues"
  },
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "comment": "ARM64 instructions — red",
            "scope": [
              "keyword.mnemonic.branch.arm64",
              "keyword.mnemonic.memory.arm64",
              "keyword.mnemonic.arithmetic.arm64",
              "keyword.mnemonic.logical.arm64",
              "keyword.mnemonic.simd.arm64",
              "keyword.mnemonic.system.arm64"
            ],
            "settings": { "foreground": "#cd6f6f" }
          },
          {
            "comment": "ARM64 function / macro calls — yellow",
            "scope": "entity.name.function.call.arm64",
            "settings": { "foreground": "#dcdcaa" }
          },
          {
            "comment": "ARM64 stack pointer (SP / WSP) — cyan-blue, distinct from other GPRs",
            "scope": "variable.language.register.stack-pointer.arm64",
            "settings": { "foreground": "#4fc1ff" }
          },
          {
            "comment": "ARM64 entry labels (START / END) — magenta",
            "scope": "entity.name.label.entry.arm64",
            "settings": { "foreground": "#c586c0" }
          }
        ]
      }
    },
    "languages": [
      {
        "id": "arm64-asm",
        "aliases": [
          "ARM64 Assembly",
          "AArch64 Assembly",
          "arm64-asm"
        ],
        "extensions": [
          ".s",
          ".S"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "arm64-asm",
        "scopeName": "source.arm64",
        "path": "./syntaxes/arm64-asm.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.115.0",
    "typescript": "^5.9.3"
  }
}
